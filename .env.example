# Stellar Crowdfunding — Environment Variables Template
# Copy this to frontend/.env and fill in the values after deployment.

VITE_CROWDFUNDING_CONTRACT_ID=
VITE_TOKEN_CONTRACT_ID=
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
VITE_RPC_URL=https://soroban-testnet.stellar.org

# Fee Sponsorship (Optional)
# Add a Stellar secret key here to enable gasless transactions for your users.
# The sponsor account will pay all XLM transaction fees.
VITE_SPONSOR_SECRET_KEY=

# Add your custom API keys here if needed

